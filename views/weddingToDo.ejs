<!DOCTYPE html>

<html>
  <head>
    <title>Amazing Mr. Wade</title>

    <link rel="stylesheet" href="https://bootswatch.com/5/darkly/bootstrap.css"> <!--Boostrap Styling-->
    <!--This is Code for Fonts-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lavishly+Yours&display=swap" rel="stylesheet">
    <!--_______________________-->
    <link rel="stylesheet" href="/styles/alt.css"> <!--Modification to Styling-->
  </head>
  <body>
    <header>
        <%- include("header/header.ejs") %>
    </header>

    <!-- Our Dynamic Table-->
    <table class="table table-dark">
      <thead>
        <tr>
          <th scope="col"> </th>
          <th scope="col">Item</th>
          <th scope="col">Note</th>
        </tr>
      </thead>
      <tbody>
        <% for(let item of listItem){%> 
          <tr class="table">
            
            <!--TODO: Need to add Edit-->
            <th> 
              <div>
                <form action="/delete" method="post">
                  <input class="form-check-input" type="checkbox" value="" onchange="this.form.submit()" id=<%=item.id%>>
                </form>
              </div>
            </th>
            <td><%=item.title %></th>
            <td><%= item.note %></td>
          </tr>
        <% } %>
      </tbody>
    </div>

  </body>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</html>

